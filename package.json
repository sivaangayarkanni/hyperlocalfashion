{
  "name": "rewear-platform",
  "version": "1.0.0",
  "description": "Hyperlocal platform connecting users with nearby tailors",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install && cd ../server/mcp && npm install",
    "install-mcp": "cd server/mcp && npm install",
    "verify-setup": "node verify-setup.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:bot": "node test-intelligent-bot.js"
  },
  "keywords": [
    "tailoring",
    "repair",
    "sustainability"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/server/tests/setup.js"],
    "testMatch": ["<rootDir>/server/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "server/services/**/*.js",
      "server/routes/**/*.js",
      "!server/tests/**"
    ]
  }
}
